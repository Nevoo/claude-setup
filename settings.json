      "Diving",
      "Surfacing",
      "Rafting up",
      "Pebble-polishing",
      "Floating downstream",
      "Shucking"
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "agentPushNotifEnabled": true
