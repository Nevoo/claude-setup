  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model_name=$(echo \"$input\" | jq -r '.model.display_name'); used_pct=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); dir_name=$(basename \"$current_dir\"); git_branch=\"\"; if git -C \"$current_dir\" rev-parse --git-dir > /dev/null 2>&1; then git_branch=$(git -C \"$current_dir\" --no-optional-locks branch --show-current 2>/dev/null); [ -n \"$git_branch\" ] && git_branch=\" on $(printf '\\033[35m')$git_branch$(printf '\\033[0m')\"; fi; context_info=\"\"; if [ -n \"$used_pct\" ]; then if (( $(echo \"$used_pct >= 80\" | bc -l 2>/dev/null || echo 0) )); then context_color=\"31\"; elif (( $(echo \"$used_pct >= 50\" | bc -l 2>/dev/null || echo 0) )); then context_color=\"33\"; else context_color=\"32\"; fi; context_info=\" | $(printf '\\033[')${context_color}m${used_pct}%$(printf '\\033[0m') used\"; fi; otter=$(printf '%s' \"$input\" | /Users/rouven/Developer/personal/projects/tools/otterly/packages/cli/dist/otterly statusline 2>/dev/null); printf '%s\\033[36m%s\\033[0m%s | \\033[34m%s\\033[0m%s' \"${otter:+$otter }\" \"$dir_name\" \"$git_branch\" \"$model_name\" \"$context_info\""
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
